/* MODERN MENUKE THEME 2026 */
:root {
    --ww-green: #00501a;
    --ww-light: #f3f7f4;
    --ww-gold: #ffb800;
    --text-main: #1a1a1a;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
    --shadow-lg: 0 10px 30px rgba(0,0,0,0.08);
}

body {
    font-family: 'Inter', 'Segoe UI', sans-serif;
    background-color: #fafafa;
    color: var(--text-main);
    margin: 0;
}
/* GLASSMORPHISM CARD ENHANCEMENT */
:root {
    --glass-bg: rgba(255, 255, 255, 0.75);
    --glass-border: rgba(255, 255, 255, 0.4);
    --glass-blur: 12px;
}

.card-panel {
    background: var(--glass-bg);
    
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    
    border: 1px solid var(--glass-border);
    border-radius: 28px; /* Slightly rounder for a softer look */
    
    /* Layered shadow for depth without looking dirty */
    box-shadow: 
        0 4px 6px -1px rgba(0, 0, 0, 0.05),
        0 20px 40px -10px rgba(0, 0, 0, 0.1);
        
    padding: 40px;
    margin-top: -60px; /* Pulls it higher into the hero image */
    transition: transform 0.3s ease;
}

/* Enhancing the search input inside the glass card */
.modern-select {
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(0, 80, 26, 0.1);
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
}

.modern-select:hover {
    background: #ffffff;
    border-color: var(--ww-green);
}

/* Adding a subtle glow to the primary button */
.btn-action {
    box-shadow: 0 4px 15px rgba(0, 80, 26, 0.3);
}

.btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 80, 26, 0.4);
}

/* HERO SECTION */
.hero {
    background: linear-gradient(rgba(0, 80, 26, 0.85), rgba(0, 80, 26, 0.85)), 
                url('https://images.unsplash.com/photo-1542831371-29b0f74f9713?auto=format&fit=crop&q=80&w=1400');
    background-size: cover;
    background-position: center;
    color: white;
    padding: 80px 5%;
    text-align: center;
    border-radius: 0 0 40px 40px;
}

.hero h1 { font-size: 2.5rem; margin-bottom: 10px; }

@media (max-width: 768px) {
    .hero { padding: 60px 5%; border-radius: 0 0 24px 24px; }
    .hero h1 { font-size: 1.8rem; }
    .hero p { font-size: 0.95rem; }
}

@media (max-width: 480px) {
    .hero { padding: 40px 5%; }
    .hero h1 { font-size: 1.4rem; margin-bottom: 8px; }
}

/* BENTO LAYOUT CONTAINERS */
.container { max-width: 1100px; margin: -40px auto 60px; padding: 0 20px; }

@media (max-width: 768px) {
    .container { margin: -30px auto 40px; padding: 0 15px; }
}

@media (max-width: 480px) {
    .container { margin: -20px auto 30px; padding: 0 12px; }

.card-panel {
    background: white;
    border-radius: 24px;
    padding: 30px;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0,0,0,0.03);
    margin-bottom: 30px;
}

@media (max-width: 768px) {
    .card-panel { padding: 24px; border-radius: 18px; margin-bottom: 24px; }
}

@media (max-width: 480px) {
    .card-panel { padding: 16px; border-radius: 14px; margin-bottom: 16px; }

/* MODERN RECIPE CARDS */
.recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
}

@media (max-width: 1024px) {
    .recipe-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
}

@media (max-width: 768px) {
    .recipe-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
}

@media (max-width: 480px) {
    .recipe-grid { grid-template-columns: 1fr; gap: 12px; }

.recipe-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid #f0f0f0;
}

.recipe-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
}

.recipe-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    position: relative;
}

@media (max-width: 768px) {
    .recipe-image { height: 160px; }
}

@media (max-width: 480px) {
    .recipe-image { height: 140px; }

.nutri-badge {
    position: absolute;
    top: 15px; left: 15px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(5px);
    padding: 5px 12px;
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ww-green);
}

.favorite-btn {
    position: absolute;
    top: 10px; right: 10px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(5px);
    border: none;
    padding: 8px 12px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 1.2rem;
    transition: all 0.2s;
}

.favorite-btn:hover {
    transform: scale(1.1);
    background: white;
}

.recipe-content {
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.type-tag {
    display: inline-block;
    background: var(--ww-light);
    color: var(--ww-green);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
}

.recipe-content h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-main);
    line-height: 1.3;
}

.calorie-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ww-green);
}

.day-selector {
    width: 100% !important;
    padding: 10px !important;
    border-radius: 8px !important;
    border: 2px solid #eef2f0 !important;
    font-size: 0.9rem !important;
    color: var(--ww-green) !important;
    font-weight: 600 !important;
    cursor: pointer;
    transition: border-color 0.2s;
}

.day-selector:focus {
    outline: none;
    border-color: var(--ww-green) !important;
}

/* WEEKLY PLANNER GRID */
#weekly-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 12px;
}

@media (max-width: 1024px) {
    #weekly-grid { gap: 10px; }
}

@media (max-width: 768px) {
    #weekly-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
}

@media (max-width: 480px) {
    #weekly-grid { grid-template-columns: repeat(2, 1fr); gap: 6px; }
    .weekly-day-card { padding: 10px 6px; min-height: 100px; }
    .weekly-day-card h4 { font-size: 0.65rem; margin-bottom: 6px; }
    .planned-meal-name { font-size: 0.65rem; padding: 6px; }

.weekly-day-card {
    background: var(--ww-light);
    border: 2px dashed #dce5df;
    border-radius: 16px;
    padding: 15px 10px;
    text-align: center;
    min-height: 120px;
}

.weekly-day-card h4 {
    margin: 0 0 10px 0;
    color: var(--ww-green);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.planned-meal-name {
    background: white;
    border: 1px solid #eee;
    padding: 8px;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
}


/* BUTTONS */
.btn-action {
    background: var(--ww-green);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
}

@media (max-width: 480px) {
    .btn-action { padding: 10px 16px; font-size: 0.9rem; }

.btn-reset {
    background: #fff0f0;
    color: #e63946;
    border: 1px solid #ffdcdc;
    font-size: 0.75rem;
}

.btn-reset:hover { background: #fee2e2; }


/* MODERN SELECT DROPDOWN */
.modern-select {
    width: 100%;
    padding: 15px;
    border-radius: 12px;
    border: 2px solid #eef2f0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ww-green);
    background-color: #f9fbf9;
    cursor: pointer;
    transition: border-color 0.3s;
}

.modern-select:focus {
    outline: none;
    border-color: var(--ww-green);
}

@media (max-width: 480px) {
    .modern-select { padding: 12px; font-size: 0.95rem; }
}

@media (max-width: 768px) {
    #weekly-grid { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); }
}

/* Saved meals count badge */
.saved-count-badge {
    display: inline-block;
    background: var(--ww-gold);
    color: #1a1a1a;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 0.85rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

/* UI TWEAKS: Reduce bulky elements, tighten spacing, and soften visuals */
.hero {
    padding: 56px 5%; /* shorter hero */
    background: linear-gradient(rgba(0,80,26,0.60), rgba(0,80,26,0.55)), url('https://images.unsplash.com/photo-1542831371-29b0f74f9713?auto=format&fit=crop&q=80&w=1400');
    background-size: cover;
    background-position: center;
    min-height: 220px;
    border-radius: 0 0 20px 20px;
}

.card-panel {
    margin-top: 0; /* remove heavy negative pull */
    transform: translateY(-20px); /* subtle lift */
    padding: 28px;
    border-radius: 16px;
}

.recipe-image { height: 140px; }
.recipe-card { border-radius: 14px; padding-bottom: 12px; }
.recipe-content h3 { font-size: 1rem; }

/* Buttons: smaller, subtler shadow and clearer print CTA */
.btn-action {
    border-radius: 12px;
    padding: 10px 18px;
    box-shadow: 0 6px 14px rgba(0,80,26,0.12);
    transition: transform .14s ease, box-shadow .14s ease;
}
.btn-action:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,80,26,0.14); }
.btn-print { background: #FFB800; color: #111; }

/* Planner cards: replace dashed borders with soft solid borders */
.weekly-day-card {
    border: 1px solid #e9f1ec;
    background: #fff;
    min-height: 110px;
    padding: 12px;
}

/* Saved badge: smaller inline, no heavy shadow */
.saved-count-badge {
    padding: 2px 8px;
    font-size: 0.8rem;
    border-radius: 999px;
    background: #ffb800;
    color: #111;
    box-shadow: none;
}

/* Topbar / brand and food hero styles */
.topbar { background: #fff; border-bottom: 1px solid #eef3ee; }
.topbar-inner { display:flex; align-items:center; gap:12px; max-width: 1200px; margin: 0 auto; padding: 10px 20px; flex-wrap: wrap; }
.brand-logo { width:56px; height:56px; object-fit:contain; flex-shrink: 0; }
.brand { flex-shrink: 0; margin: 0; }
.brand-motto { margin: 0; font-size: 0.85rem; color: var(--ww-green); font-weight: 700; white-space: nowrap; flex-shrink: 0; }

/* Search bar in header */
.topbar-search { display:flex; align-items:center; gap:8px; flex:1; max-width: 300px; background: #f9fbf9; border: 1px solid #e9f1ec; border-radius: 10px; padding: 8px 12px; margin: 0 12px; }
.search-input { flex: 1; background: none; border: none; outline: none; font-size: 0.9rem; color: var(--ww-green); font-weight: 500; }
.search-input::placeholder { color: #bbb; }
.topbar-search i { color: #aaa; font-size: 0.9rem; }

/* Favorites quick link in header */
.favorites-quick-link { display:flex; align-items:center; gap:6px; color: var(--ww-green); text-decoration: none; font-size: 1.2rem; position: relative; transition: all 200ms ease; flex-shrink: 0; }
.favorites-quick-link:hover { color: #ff6b6b; transform: scale(1.08); }
.fav-count-badge { position: absolute; top: -8px; right: -8px; background: #ff6b6b; color: #fff; font-size: 0.65rem; font-weight: 700; width: 20px; height: 20px; border-radius: 50%; display:flex; align-items:center; justify-content:center; }
.fav-count-badge.hidden { display: none; }

@media (max-width: 900px) {
    .topbar-search { max-width: 200px; }
    .search-input { font-size: 0.85rem; }
}
@media (max-width: 720px) {
    .topbar-inner { gap: 10px; }
    .brand-logo { width: 48px; height: 48px; }
    .brand-motto { display: none; }
    .topbar-search { display: none; }
}
.food-hero { background-image: linear-gradient(180deg, rgba(0,80,26,0.55), rgba(255,184,0,0.06)), url('https://images.unsplash.com/photo-1547592166-23ac45744acd?w=500'); background-size: cover; background-position: center; color: #fff; padding: 56px 5%; min-height: 220px; border-radius: 0 0 18px 18px; }
.hero-inner { max-width: 1000px; margin: 0 auto; text-align: center; }
.hero-ctas .btn-action, .hero-ctas .btn-print { min-width: 160px; }


/* Typography tweaks for better rhythm */
body { font-size: 16px; line-height: 1.45; }
.hero h2 { font-size: 1.6rem; margin-bottom: 8px; }

@media (max-width: 1024px) {
    body { font-size: 15px; }
}

@media (max-width: 768px) {
    body { font-size: 14px; }
    .hero { padding: 40px 4%; min-height: 180px; }
    .hero h2 { font-size: 1.3rem; }
    .recipe-image { height: 120px; }
}

@media (max-width: 480px) {
    body { font-size: 13px; line-height: 1.4; }
    .hero h2 { font-size: 1rem; }
    h2 { font-size: 1.3rem; margin-bottom: 12px; }
    h3 { font-size: 1rem; }
}

/* Visual polish: typography, subtle motion, and refined shadows */
:root {
    --gap-sm: 8px;
    --gap-md: 16px;
    --gap-lg: 24px;
    --radius-sm: 8px;
    --radius-md: 14px;
}

/* Improve base typography and smoothing */
html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
body { font-family: Inter, 'Segoe UI', system-ui, -apple-system, 'Helvetica Neue', Arial; color: var(--text-main); }

/* Brand header styling */
.brand { font-weight: 800; letter-spacing: -0.5px; color: #0b3b24; margin: 18px 24px; }
.brand-light { font-weight: 600; color: var(--ww-green); }

/* Card shadows and interactive lift */
.card-panel { box-shadow: 0 12px 30px rgba(3,40,18,0.06); }
.recipe-card { transition: transform 220ms cubic-bezier(.2,.9,.3,1), box-shadow 220ms; }
.recipe-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(6,34,18,0.08); }

/* Recipe image: gentle overlay for text legibility */
.recipe-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.0) 40%, rgba(0,0,0,0.06) 65%, rgba(0,0,0,0.12) 100%);
    pointer-events: none;
}

/* Thumbnails micro-interaction */
.meal-thumbs img { transition: transform 160ms ease, box-shadow 160ms ease; }
.meal-thumbs img:hover { transform: translateY(-4px) scale(1.03); box-shadow: 0 8px 18px rgba(0,0,0,0.08); }

/* Button microcopy and icon spacing */
.btn-action i { margin-right: 8px; opacity: 0.95; }
.btn-print i { margin-right: 6px; }

/* Planner card hover and focus */
.weekly-day-card { transition: transform 200ms ease, box-shadow 200ms ease; }
.weekly-day-card:hover { transform: translateY(-6px); box-shadow: 0 18px 36px rgba(3,40,18,0.06); }

/* Subtle entrance animation for key cards */
@keyframes popIn { from { opacity: 0; transform: translateY(6px) scale(0.995); } to { opacity: 1; transform: translateY(0) scale(1); } }
.recipe-card, .card-panel { animation: popIn 280ms ease both; }

/* Small utility: reduce overly-large paddings on small screens */
@media (max-width: 520px) {
    .card-panel { padding: 18px; border-radius: 12px; }
    .recipe-content { padding: 12px; }
    .btn-action { padding: 8px 14px; }
}

/* Filter chip buttons - polished styling */
.filter-chip {
    background: #f9fbf9;
    color: var(--ww-green);
    border: 2px solid #e9f1ec;
    padding: 10px 18px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 200ms cubic-bezier(0.2, 0.9, 0.3, 1);
    display: inline-block;
    margin: 0 6px;
}

.filter-chip:hover {
    transform: translateY(-2px);
    border-color: var(--ww-green);
    box-shadow: 0 4px 12px rgba(0, 80, 26, 0.1);
    background: #fff;
}

.filter-chip.active {
    background: var(--ww-green);
    color: white;
    border-color: var(--ww-green);
    box-shadow: 0 8px 20px rgba(0, 80, 26, 0.2);
}

.filter-chip.active:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(0, 80, 26, 0.25);
}

@media (max-width: 768px) {
    .filter-chip { padding: 8px 14px; font-size: 0.85rem; margin: 0 4px; }
}

@media (max-width: 480px) {
    .filter-chip { padding: 6px 10px; font-size: 0.75rem; margin: 0 2px; }
}
